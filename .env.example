# Required site and auth configuration
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# Postgres / Prisma database connection
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio
# Optional direct connection string that bypasses connection pooling
DIRECT_URL=postgresql://user:password@localhost:5432/portfolio

# Admin login and GitHub OAuth
ADMIN_EMAIL=admin@example.com
ADMIN_GITHUB_LOGIN=github_username
GITHUB_ID=github_oauth_app_client_id
GITHUB_SECRET=github_oauth_app_client_secret

# SMTP config for contact form delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASS=your_smtp_password

# Optional Supabase / Postgres helper variables
# These are not required for the app, but are included for Supabase-hosted projects.
NEXT_PUBLIC_POSTGRES_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_POSTGRES_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_POSTGRES_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
POSTGRES_SUPABASE_URL=https://your-supabase-project.supabase.co
POSTGRES_SUPABASE_ANON_KEY=your_supabase_anon_key
POSTGRES_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
POSTGRES_SUPABASE_SECRET_KEY=your_supabase_secret_key
POSTGRES_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
POSTGRES_SUPABASE_JWT_SECRET=your_supabase_jwt_secret
POSTGRES_URL=postgres://user:password@localhost:5432/portfolio
POSTGRES_URL_NON_POOLING=postgres://user:password@localhost:5432/portfolio
POSTGRES_PRISMA_URL=postgres://user:password@localhost:5432/portfolio
POSTGRES_HOST=localhost
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_database_password

# VERCEL_OIDC_TOKEN is generated automatically by Vercel and should not be committed to source control.
# VERCEL_OIDC_TOKEN=your_vercel_oidc_token

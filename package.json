{
    "name": "portfolio",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:migrate:prod": "cross-env DRIZZLE_ENV=production drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:seed": "tsx --env-file .env.local src/db/seed.ts",
        "db:seed:prod": "tsx --env-file .env.production src/db/seed.ts",
        "db:studio": "drizzle-kit studio",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "smoke:contact": "node scripts/local/contact-smoke.mjs"
    },
    "dependencies": {
        "@auth/drizzle-adapter": "^1.11.2",
        "@hookform/resolvers": "^5.2.2",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "botid": "^1.5.11",
        "drizzle-orm": "^0.45.2",
        "framer-motion": "^12.38.0",
        "lucide-react": "^1.14.0",
        "next": "^16.2.4",
        "next-auth": "^4.24.14",
        "postgres": "^3.4.9",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-hook-form": "^7.74.0",
        "react-icons": "^5.6.0",
        "react-phone-number-input": "^3.4.16",
        "sonner": "^2.0.7",
        "zod": "^4.4.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@tailwindcss/postcss": "^4",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.6.0",
        "@types/nodemailer": "^8.0.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^6.0.1",
        "cross-env": "^10.1.0",
        "dotenv": "^17.4.2",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.4",
        "jsdom": "^29.1.1",
        "nodemailer": "^8.0.7",
        "prettier": "^3.8.3",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "^6",
        "vitest": "^4.1.5"
    }
}
